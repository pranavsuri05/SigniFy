{
    "manifest_version": 3,
    "name": "SigniFy - Google Meet Sign Language Extension",
    "version": "1.0",
    "description": "Real-time sign language recognition in Google Meet.",
    "permissions": ["activeTab"],
    "host_permissions": ["https://meet.google.com/*"],
    "content_scripts": [
        {
            "matches": ["https://meet.google.com/*"],
            "js": ["content.js"]
        }
    ],
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    }
}